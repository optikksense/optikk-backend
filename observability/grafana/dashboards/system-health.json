{
  "title": "Optikk — System Health",
  "uid": "optikk-system-health",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["optikk", "runtime"],
  "timezone": "browser",
  "panels": [
    {
      "type": "timeseries",
      "title": "Go heap in use",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "go_memstats_heap_inuse_bytes{job=\"optikk-api\"}",
          "legendFormat": "heap_inuse"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Goroutines",
      "id": 2,
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "go_goroutines{job=\"optikk-api\"}",
          "legendFormat": "goroutines"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "GC pause",
      "id": 3,
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(go_gc_duration_seconds_sum{job=\"optikk-api\"}[5m])",
          "legendFormat": "gc pause /s"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP request rate (RED)",
      "id": 10,
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (code) (rate(promhttp_metric_handler_requests_total{job=\"optikk-api\"}[1m]))",
          "legendFormat": "{{code}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "OTel collector drops / queue",
      "id": 11,
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(otelcol_exporter_send_failed_spans_total[1m])) by (exporter)",
          "legendFormat": "failed {{exporter}}"
        },
        {
          "refId": "B",
          "expr": "sum(otelcol_exporter_queue_size) by (exporter)",
          "legendFormat": "queue {{exporter}}"
        }
      ]
    }
  ]
}
