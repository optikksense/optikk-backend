{
  "title": "Optikk — API Latency",
  "uid": "optikk-api-latency",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["optikk", "api"],
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "constant",
        "current": { "value": "optikk-backend", "text": "optikk-backend" },
        "query": "optikk-backend",
        "hide": 2
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "p95 — POST /traces/query",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceqlMetrics",
          "query": "{ resource.service.name=\"optikk-backend\" && name=\"POST /api/v1/traces/query\" } | quantile_over_time(duration, 0.95)"
        }
      ]
    },
    {
      "type": "stat",
      "title": "p95 — GET /traces/:id/bundle",
      "id": 2,
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceqlMetrics",
          "query": "{ resource.service.name=\"optikk-backend\" && name=~\"GET /api/v1/traces/.*/bundle\" } | quantile_over_time(duration, 0.95)"
        }
      ]
    },
    {
      "type": "stat",
      "title": "p95 — POST /logs/query",
      "id": 3,
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceqlMetrics",
          "query": "{ resource.service.name=\"optikk-backend\" && name=\"POST /api/v1/logs/query\" } | quantile_over_time(duration, 0.95)"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency by endpoint — p50 / p95 / p99",
      "id": 10,
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 10 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceqlMetrics",
          "query": "{ resource.service.name=\"$service\" } | quantile_over_time(duration, 0.50) by (name)",
          "legendFormat": "p50 {{name}}"
        },
        {
          "refId": "B",
          "queryType": "traceqlMetrics",
          "query": "{ resource.service.name=\"$service\" } | quantile_over_time(duration, 0.95) by (name)",
          "legendFormat": "p95 {{name}}"
        },
        {
          "refId": "C",
          "queryType": "traceqlMetrics",
          "query": "{ resource.service.name=\"$service\" } | quantile_over_time(duration, 0.99) by (name)",
          "legendFormat": "p99 {{name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request rate — by endpoint",
      "id": 11,
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceqlMetrics",
          "query": "{ resource.service.name=\"$service\" } | rate() by (name)"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error rate — by endpoint",
      "id": 12,
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceqlMetrics",
          "query": "{ resource.service.name=\"$service\" && status=error } | rate() by (name)"
        }
      ]
    }
  ]
}
