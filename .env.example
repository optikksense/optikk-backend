# Copy to `.env` for `docker compose up`. `.env` is gitignored so real
# credentials never land in the repo.

# Grafana Cloud OTLP gateway that receives self-telemetry from the
# otel-collector. Stack-specific — find this URL under
# https://grafana.com/orgs/<org>/stacks/<stack> → "Details" → OTLP endpoint.
GRAFANA_CLOUD_OTLP_ENDPOINT=https://otlp-gateway-prod-<region>.grafana.net/otlp

# Basic auth header value. Generate at
# https://grafana.com/orgs/<org>/stacks/<stack>/otlp-info — it produces the
# base64-encoded "<instance_id>:<access_policy_token>" string. Paste the
# full header value INCLUDING the leading "Basic " token.
GRAFANA_CLOUD_OTLP_AUTH=Basic <base64-encoded-instance-id-colon-token>
