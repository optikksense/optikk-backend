# VM configuration (Multipass)
VM_NAME=obs-loadtest
VM_CPUS=2
VM_MEMORY=4G
VM_DISK=20G

# Backend replicas (the "x" pods behind nginx)
BACKEND_REPLICAS=2

# ClickHouse configuration (the "y" pods with "a" CPUs, "b" memory)
CLICKHOUSE_REPLICAS=1
CLICKHOUSE_CPUS=1.0
CLICKHOUSE_MEMORY=1g
CLICKHOUSE_PASSWORD=clickhouse123

# MariaDB configuration
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=observability

# Kafka configuration (KRaft mode)
KAFKA_KRAFT_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# Backend tuning
QUEUE_BATCH_SIZE=500
QUEUE_FLUSH_INTERVAL_MS=2000
