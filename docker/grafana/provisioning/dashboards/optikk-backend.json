{
  "title": "Optikk Backend",
  "uid": "optikk-backend",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["optikk"],
  "panels": [
    {
      "id": 1,
      "title": "CH query p95 (seconds)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, profile) (rate(optikk_ch_query_duration_seconds_bucket[5m])))",
          "legendFormat": "{{profile}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Ingest flush rate (ops/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (signal, result) (rate(optikk_ingest_flush_total[1m]))",
          "legendFormat": "{{signal}} {{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "DLQ produce rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (signal) (rate(optikk_ingest_dlq_total[5m]))",
          "legendFormat": "{{signal}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Alert evaluator tick duration",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(optikk_alert_eval_duration_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Alert outbox backlog",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "optikk_alert_outbox_backlog",
          "legendFormat": "pending",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Live-tail subscribers",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum by (team_id) (optikk_livetail_subscribers)",
          "legendFormat": "team {{team_id}}",
          "refId": "A"
        }
      ]
    }
  ]
}
