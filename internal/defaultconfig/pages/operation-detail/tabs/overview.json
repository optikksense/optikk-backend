{
  "id": "overview",
  "pageId": "operation-detail",
  "label": "Overview",
  "order": 10,
  "sections": [
    {
      "id": "signals",
      "title": "Signals",
      "order": 10,
      "kind": "trends",
      "collapsible": true,
      "layoutMode": "three-up"
    },
    {
      "id": "quality",
      "title": "Quality",
      "order": 20,
      "kind": "breakdowns",
      "collapsible": true,
      "layoutMode": "two-up"
    }
  ],
  "panels": [
    {
      "id": "op-request-rate",
      "layout": {
        "preset": "trend"
      },
      "order": 10,
      "query": {
        "endpoint": "/v1/spans/red/request-rate",
        "method": "GET",
        "params": {
          "service": "{serviceName}",
          "operation": "{operationName}"
        }
      },
      "title": "Request Rate",
      "titleIcon": "TrendingUp",
      "panelType": "request",
      "sectionId": "signals"
    },
    {
      "id": "op-error-rate",
      "layout": {
        "preset": "trend"
      },
      "order": 20,
      "query": {
        "endpoint": "/v1/spans/red/error-rate",
        "method": "GET",
        "params": {
          "service": "{serviceName}",
          "operation": "{operationName}"
        }
      },
      "title": "Error Rate",
      "titleIcon": "AlertCircle",
      "panelType": "error-rate",
      "sectionId": "signals"
    },
    {
      "id": "op-p95-latency",
      "layout": {
        "preset": "trend"
      },
      "order": 30,
      "query": {
        "endpoint": "/v1/spans/red/p95-latency",
        "method": "GET",
        "params": {
          "service": "{serviceName}",
          "operation": "{operationName}"
        }
      },
      "title": "p95 Latency",
      "titleIcon": "Clock",
      "valueKey": "p95",
      "panelType": "latency",
      "sectionId": "signals"
    },
    {
      "id": "op-apdex",
      "layout": {
        "preset": "breakdown"
      },
      "order": 40,
      "query": {
        "endpoint": "/v1/spans/red/apdex",
        "method": "GET",
        "params": {
          "service": "{serviceName}",
          "operation": "{operationName}",
          "satisfied_ms": 300,
          "tolerating_ms": 1200
        }
      },
      "title": "Apdex Score",
      "titleIcon": "Target",
      "valueKey": "apdex",
      "panelType": "gauge",
      "sectionId": "quality"
    },
    {
      "id": "op-http-status",
      "layout": {
        "preset": "breakdown"
      },
      "order": 50,
      "query": {
        "endpoint": "/v1/spans/red/http-status-distribution",
        "method": "GET",
        "params": {
          "service": "{serviceName}",
          "operation": "{operationName}"
        }
      },
      "title": "HTTP Status Distribution",
      "titleIcon": "BarChart2",
      "valueKey": "count",
      "panelType": "bar",
      "sectionId": "quality"
    }
  ]
}
