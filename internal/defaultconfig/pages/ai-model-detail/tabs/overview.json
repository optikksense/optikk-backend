{
  "id": "overview",
  "pageId": "ai-model-detail",
  "label": "Overview",
  "order": 10,
  "groups": [
    { "id": "summary", "label": "Summary", "order": 10 },
    { "id": "trends", "label": "Trends", "order": 20 }
  ],
  "components": [
    {
      "componentKey": "stat-card",
      "groupId": "summary",
      "id": "model-total-requests",
      "layout": { "col": 6 },
      "order": 10,
      "query": {
        "endpoint": "/v1/ai/summary",
        "method": "GET",
        "params": { "model": "{modelName}" }
      },
      "title": "Total Requests",
      "titleIcon": "Activity"
    },
    {
      "componentKey": "stat-card",
      "groupId": "summary",
      "id": "model-total-cost",
      "layout": { "col": 6 },
      "order": 20,
      "query": {
        "endpoint": "/v1/ai/summary",
        "method": "GET",
        "params": { "model": "{modelName}" }
      },
      "title": "Total Cost",
      "titleIcon": "DollarSign"
    },
    {
      "componentKey": "stat-card",
      "groupId": "summary",
      "id": "model-guardrail-blocks",
      "layout": { "col": 6 },
      "order": 30,
      "query": {
        "endpoint": "/v1/ai/summary",
        "method": "GET",
        "params": { "model": "{modelName}" }
      },
      "title": "Guardrail Blocks",
      "titleIcon": "Shield"
    },
    {
      "componentKey": "stat-card",
      "groupId": "summary",
      "id": "model-pii-detections",
      "layout": { "col": 6 },
      "order": 40,
      "query": {
        "endpoint": "/v1/ai/summary",
        "method": "GET",
        "params": { "model": "{modelName}" }
      },
      "title": "PII Detections",
      "titleIcon": "Eye"
    },
    {
      "componentKey": "ai-line",
      "groupId": "trends",
      "id": "model-qps",
      "layout": { "col": 12 },
      "order": 50,
      "query": {
        "endpoint": "/v1/ai/performance/timeseries",
        "method": "GET",
        "params": { "model": "{modelName}", "interval": "5m" }
      },
      "title": "QPS",
      "titleIcon": "TrendingUp"
    },
    {
      "componentKey": "ai-line",
      "groupId": "trends",
      "id": "model-cost-over-time",
      "layout": { "col": 12 },
      "order": 60,
      "query": {
        "endpoint": "/v1/ai/cost/timeseries",
        "method": "GET",
        "params": { "model": "{modelName}", "interval": "5m" }
      },
      "title": "Cost Over Time",
      "titleIcon": "DollarSign"
    }
