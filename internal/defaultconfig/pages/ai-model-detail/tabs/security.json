{
  "id": "security",
  "pageId": "ai-model-detail",
  "label": "Security",
  "order": 40,
  "components": [
    {
      "componentKey": "ai-line",
      "id": "model-pii-timeseries",
      "layout": { "col": 12 },
      "order": 10,
      "query": {
        "endpoint": "/v1/ai/security/timeseries",
        "method": "GET",
        "params": { "model": "{modelName}", "interval": "5m" }
      },
      "title": "PII Detections Over Time",
      "titleIcon": "Eye"
    },
    {
      "componentKey": "ai-bar",
      "id": "model-pii-categories",
      "layout": { "col": 12 },
      "order": 20,
      "query": {
        "endpoint": "/v1/ai/security/pii-categories",
        "method": "GET",
        "params": { "model": "{modelName}" }
      },
      "title": "PII Categories",
      "titleIcon": "Shield"
    },
    {
      "componentKey": "table",
      "id": "model-security-metrics",
      "layout": { "col": 24 },
      "order": 30,
      "query": {
        "endpoint": "/v1/ai/security/metrics",
        "method": "GET",
        "params": { "model": "{modelName}" }
      },
      "title": "Security Metrics",
      "titleIcon": "Shield"
    }
  ]
}
