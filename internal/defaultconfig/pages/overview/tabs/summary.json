      "title": "Key Metrics",
      "order": 5,
      "kind": "details",
      "collapsible": true,
      "layoutMode": "stack"
    },
    {
      "id": "golden-signals",
      "title": "Golden Signals",
      "order": 10,
      "kind": "trends",
      "collapsible": true,
      "layoutMode": "two-up"
    },
    {
      "id": "service-health",
      "title": "Service Health",
      "order": 20,
      "kind": "breakdowns",
      "collapsible": true,
      "layoutMode": "three-up"
    },
    {
      "id": "top-consumers",
      "title": "Top Consumers",
      "order": 30,
      "kind": "details",
      "collapsible": true,
      "layoutMode": "two-up"
    }
  ],
  "panels": [
    {
      "id": "overview-stat-cards",
      "layout": {
        "preset": "detail"
      },
      "order": 1,
      "query": {
        "endpoint": "/v1/overview/services",
        "method": "GET"
      },
      "title": "Overview Stats",
      "panelType": "stat-cards-grid",
      "sectionId": "overview-stats"
    },
    {
      "id": "slo-indicators",
      "layout": {
        "preset": "detail"
      },
      "order": 2,
      "query": {
        "endpoint": "/v1/overview/services",
        "method": "GET"
      },
      "title": "SLO Indicators",
      "panelType": "slo-indicators",
      "sectionId": "overview-stats"
    },
    {
      "id": "service-health-grid",
      "layout": {
        "preset": "detail"
      },
      "order": 3,
      "query": {
        "endpoint": "/v1/overview/services",
        "method": "GET"
      },
      "title": "Services Overview",
      "panelType": "service-health-grid",
      "sectionId": "overview-stats"
    },
    {
      "groupByKey": "service_name",
      "id": "request-rate",
      "layout": {
        "preset": "trend"
      },
      "order": 10,
      "query": {
        "endpoint": "/v1/overview/request-rate",
        "method": "GET"
      },
      "title": "Request Rate",
      "titleIcon": "TrendingUp",
      "panelType": "request",
      "sectionId": "golden-signals"
    },
    {
      "groupByKey": "service_name",
      "id": "error-rate",
      "layout": {
        "preset": "trend"
      },
      "order": 20,
      "query": {
        "endpoint": "/v1/overview/error-rate",
        "method": "GET"
      },
      "title": "Error Rate",
      "titleIcon": "AlertCircle",
      "panelType": "error-rate",
      "sectionId": "golden-signals"
    },
    {
      "groupByKey": "service_name",
      "id": "p95-latency",
      "layout": {
        "preset": "hero"
      },
      "order": 30,
      "query": {
        "endpoint": "/v1/overview/p95-latency",
        "method": "GET"
      },
      "title": "p95 Latency",
      "titleIcon": "Clock",
      "valueKey": "p95",
      "panelType": "latency",
      "sectionId": "golden-signals"
    },
    {
      "id": "service-scorecard",
      "layout": {
        "preset": "breakdown"
      },
      "order": 40,
      "query": {
        "endpoint": "/v1/spans/red/service-scorecard",
        "method": "GET"
      },
      "title": "Service Scorecard",
      "titleIcon": "Activity",
      "panelType": "scorecard",
      "sectionId": "service-health"
    },
    {
      "groupByKey": "service_name",
      "id": "apdex-scores",
      "layout": {
        "preset": "breakdown"
      },
      "order": 50,
      "query": {
        "endpoint": "/v1/spans/red/apdex",
        "method": "GET",
        "params": {
          "satisfied_ms": 300,
          "tolerating_ms": 1200
        }
      },
      "title": "Apdex Score by Service",
      "titleIcon": "Target",
      "valueKey": "apdex",
      "panelType": "gauge",
      "sectionId": "service-health"
    },
    {
      "id": "error-hotspot-summary",
      "layout": {
        "preset": "breakdown"
      },
      "order": 60,
      "query": {
        "endpoint": "/v1/spans/error-hotspot",
        "method": "GET"
      },
      "title": "Error Hotspot",
      "titleIcon": "Crosshair",
      "valueKey": "error_rate",
      "xKey": "operation_name",
      "yKey": "service_name",
      "panelType": "heatmap",
      "sectionId": "service-health"
    },
    {
      "id": "services-table",
      "layout": {
        "preset": "detail"
      },
      "order": 70,
      "query": {
        "endpoint": "/v1/overview/services",
        "method": "GET"
      },
      "title": "Services",
      "titleIcon": "Layers",
      "panelType": "table",
      "sectionId": "top-consumers"
    },
    {
      "id": "endpoints-table",
      "layout": {
        "preset": "detail"
      },
      "order": 80,
      "query": {
        "endpoint": "/v1/overview/top-endpoints",
        "method": "GET"
      },
      "title": "Top Endpoints",
      "titleIcon": "List",
      "panelType": "table",
      "sectionId": "top-consumers"
    }
  ]
}
