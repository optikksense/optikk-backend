{
  "id": "errors",
  "pageId": "service-detail",
  "label": "Errors",
  "order": 30,
  "components": [
    {
      "componentKey": "exception-type-line",
      "groupByKey": "exceptionType",
      "id": "exception-rate-by-type",
      "layout": { "col": 12 },
      "order": 10,
      "query": {
        "endpoint": "/v1/spans/exception-rate-by-type",
        "method": "GET",
        "params": { "service": "{serviceName}" }
      },
      "title": "Exception Rate by Type",
      "titleIcon": "Bug",
      "valueKey": "count"
    },
    {
      "componentKey": "bar",
      "groupByKey": "http_route",
      "id": "http-5xx-by-route",
      "layout": { "col": 12 },
      "order": 20,
      "query": {
        "endpoint": "/v1/spans/http-5xx-by-route",
        "method": "GET",
        "params": { "service": "{serviceName}" }
      },
      "title": "HTTP 5xx by Route",
      "titleIcon": "AlertTriangle",
      "valueKey": "count"
    },
    {
      "componentKey": "heatmap",
      "id": "error-hotspot",
      "layout": { "col": 24 },
      "order": 30,
      "query": {
        "endpoint": "/v1/spans/error-hotspot",
        "method": "GET",
        "params": { "service": "{serviceName}" }
      },
      "title": "Error Hotspot (Operation)",
      "titleIcon": "Crosshair",
      "valueKey": "error_rate",
      "xKey": "operation_name",
      "yKey": "service_name"
