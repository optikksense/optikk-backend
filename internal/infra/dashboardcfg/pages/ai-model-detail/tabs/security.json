  "panels": [
    {
      "id": "model-pii-timeseries",
      "order": 10,
      "query": {
        "endpoint": "/v1/ai/security/timeseries",
        "method": "GET",
        "params": {
          "model": "{modelName}",
          "interval": "5m"
        }
      },
      "title": "PII Detections Over Time",
      "description": "Tracks PII detection events for this model over time. Correlate spikes with specific callers or prompt templates to identify the source.",
      "titleIcon": "Eye",
      "panelType": "ai-line",
      "sectionId": "trends",
      "layoutVariant": "wide-chart"
    },
    {
      "id": "model-pii-categories",
      "order": 20,
      "query": {
        "endpoint": "/v1/ai/security/pii-categories",
        "method": "GET",
        "params": {
          "model": "{modelName}"
        }
      },
      "title": "PII Categories",
      "description": "Breaks down detected PII by category for this model. Focus remediation on the most frequently leaked data types.",
      "titleIcon": "Shield",
      "panelType": "ai-bar",
      "sectionId": "breakdowns",
      "layoutVariant": "wide-chart"
    },
    {
      "id": "model-security-metrics",
      "order": 30,
      "query": {
        "endpoint": "/v1/ai/security/metrics",
        "method": "GET",
        "params": {
          "model": "{modelName}"
        }
      },
      "title": "Security Metrics",
      "description": "Lists security event details for this model including PII counts, guardrail blocks, and detection rates.",
      "titleIcon": "Shield",
      "panelType": "table",
      "sectionId": "details",
      "layoutVariant": "detail-table"
    }
  ]
}
