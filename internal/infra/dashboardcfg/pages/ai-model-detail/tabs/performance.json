{
  "id": "performance",
  "pageId": "ai-model-detail",
  "label": "Performance",
  "order": 20,
  "sections": [
    {
      "id": "trends",
      "title": "Golden Signals",
      "order": 20,
      "collapsible": true,
      "sectionTemplate": "two-up"
    },
    {
      "id": "breakdowns",
      "title": "Breakdowns",
      "order": 30,
      "collapsible": true,
      "sectionTemplate": "two-up"
    },
    {
      "id": "details",
      "title": "Details",
      "order": 40,
      "collapsible": true,
      "sectionTemplate": "table-stack"
    }
  ],
  "panels": [
    {
      "id": "model-avg-latency",
      "order": 10,
      "query": {
        "endpoint": "/v1/ai/performance/timeseries",
        "method": "GET",
        "params": {
          "model": "{modelName}",
          "interval": "5m"
        }
      },
      "title": "Avg Latency",
      "description": "Tracks the average inference latency for this model over time. Watch for upward trends that may indicate provider-side degradation.",
      "titleIcon": "Clock",
      "panelType": "ai-line",
      "sectionId": "trends",
      "layoutVariant": "wide-chart"
    },
    {
      "id": "model-latency-histogram",
      "order": 20,
      "query": {
        "endpoint": "/v1/ai/performance/latency-histogram",
        "method": "GET",
        "params": {
          "model": "{modelName}"
        }
      },
      "title": "Latency Histogram",
      "description": "Displays the latency distribution of inference requests for this model. A bimodal shape may indicate different prompt complexities hitting the same model.",
      "titleIcon": "BarChart2",
      "panelType": "ai-bar",
      "sectionId": "breakdowns",
      "layoutVariant": "wide-chart"
    },
    {
      "id": "model-performance-metrics",
      "order": 30,
      "query": {
        "endpoint": "/v1/ai/performance/metrics",
        "method": "GET",
        "params": {
          "model": "{modelName}"
        }
      },
      "title": "Performance Metrics",
      "description": "Lists detailed performance statistics for this model including QPS, latency percentiles, and token throughput.",
      "titleIcon": "Activity",
      "panelType": "table",
      "sectionId": "details",
      "layoutVariant": "detail-table"
    }
  ]
}
