{
  "id": "cost",
  "pageId": "ai-model-detail",
  "label": "Cost",
  "order": 30,
  "sections": [
    {
      "id": "trends",
      "title": "Golden Signals",
      "order": 20,
      "collapsible": true,
      "sectionTemplate": "two-up"
    },
    {
      "id": "breakdowns",
      "title": "Breakdowns",
      "order": 30,
      "collapsible": true,
      "sectionTemplate": "two-up"
    },
    {
      "id": "details",
      "title": "Details",
      "order": 40,
      "collapsible": true,
      "sectionTemplate": "table-stack"
    }
  ],
  "panels": [
    {
      "id": "model-cost-timeseries",
      "order": 10,
      "query": {
        "endpoint": "/v1/ai/cost/timeseries",
        "method": "GET",
        "params": {
          "model": "{modelName}",
          "interval": "5m"
        }
      },
      "title": "Cost Over Time",
      "description": "Tracks the dollar cost of this model's token usage per time interval. Look for cost anomalies that diverge from normal traffic patterns.",
      "titleIcon": "DollarSign",
      "panelType": "ai-line",
      "sectionId": "trends",
      "layoutVariant": "wide-chart"
    },
    {
      "id": "model-token-breakdown",
      "order": 20,
      "query": {
        "endpoint": "/v1/ai/cost/token-breakdown",
        "method": "GET",
        "params": {
          "model": "{modelName}"
        }
      },
      "title": "Token Breakdown",
      "description": "Shows the split of prompt, completion, system, and cache tokens for this model. Reducing prompt token volume is often the fastest path to cost savings.",
      "titleIcon": "PieChart",
      "panelType": "ai-bar",
      "sectionId": "breakdowns",
      "layoutVariant": "wide-chart"
    },
    {
      "id": "model-cost-metrics",
      "order": 30,
      "query": {
        "endpoint": "/v1/ai/cost/metrics",
        "method": "GET",
        "params": {
          "model": "{modelName}"
        }
      },
      "title": "Cost Metrics",
      "description": "Lists detailed cost statistics for this model including total spend, cost per token, and token counts by type.",
      "titleIcon": "DollarSign",
      "panelType": "table",
      "sectionId": "details",
      "layoutVariant": "detail-table"
    }
  ]
}
