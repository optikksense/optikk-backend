    {
      "id": "breakdowns",
      "title": "Breakdowns",
      "order": 30,
      "kind": "breakdowns",
      "collapsible": true,
      "layoutMode": "two-up"
    },
    {
      "id": "details",
      "title": "Details",
      "order": 40,
      "kind": "details",
      "collapsible": true,
      "layoutMode": "stack"
    }
  ],
  "panels": [
    {
      "groupByKey": "exceptionType",
      "id": "exception-rate-by-type",
      "layout": {
        "preset": "trend"
      },
      "order": 10,
      "query": {
        "endpoint": "/v1/spans/exception-rate-by-type",
        "method": "GET",
        "params": {
          "service": "{serviceName}"
        }
      },
      "title": "Exception Rate by Type",
      "description": "Tracks the occurrence rate of each exception type thrown by this service over time. A rising line for a specific type signals a regression or new failure mode worth investigating.",
      "titleIcon": "Bug",
      "valueKey": "count",
      "panelType": "exception-type-line",
      "sectionId": "trends"
    },
    {
      "groupByKey": "http_route",
      "id": "http-5xx-by-route",
      "layout": {
        "preset": "breakdown"
      },
      "order": 20,
      "query": {
        "endpoint": "/v1/spans/http-5xx-by-route",
        "method": "GET",
        "params": {
          "service": "{serviceName}"
        }
      },
      "title": "HTTP 5xx by Route",
      "description": "Breaks down server-error counts by HTTP route for this service. Compare bar heights to identify which endpoints contribute the most 5xx responses.",
      "titleIcon": "AlertTriangle",
      "valueKey": "count",
      "panelType": "bar",
      "sectionId": "breakdowns"
    },
    {
      "id": "error-hotspot",
      "layout": {
        "preset": "breakdown"
      },
      "order": 30,
      "query": {
        "endpoint": "/v1/spans/error-hotspot",
        "method": "GET",
        "params": {
          "service": "{serviceName}"
        }
      },
      "title": "Error Hotspot (Operation)",
      "description": "Displays a heatmap of error rates across operations within this service. Darker cells indicate higher error concentration, helping pinpoint the most problematic operation paths.",
      "titleIcon": "Crosshair",
      "valueKey": "error_rate",
      "xKey": "operation_name",
      "yKey": "service_name",
      "panelType": "heatmap",
      "sectionId": "breakdowns"
    },
    {
      "id": "error-groups",
      "layout": {
        "preset": "detail"
      },
      "order": 40,
      "query": {
        "endpoint": "/v1/errors/groups",
        "method": "GET",
        "params": {
          "service": "{serviceName}"
        }
      },
      "drilldownRoute": "/errors/{group_id}",
      "title": "Error Groups",
      "description": "Lists distinct error groups observed in this service, aggregated by fingerprint. Each row represents a unique error pattern -- click through to see individual occurrences and stack traces.",
      "titleIcon": "List",
      "panelType": "table",
      "sectionId": "details"
    }
  ]
}
