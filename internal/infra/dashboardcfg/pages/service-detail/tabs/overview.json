{
  "id": "overview",
  "pageId": "service-detail",
  "label": "Overview",
  "order": 10,
  "sections": [
    {
      "id": "key-metrics",
      "title": "Key Metrics",
      "order": 5,
      "kind": "details",
      "collapsible": true,
      "layoutMode": "stack"
    },
    {
      "id": "golden-signals",
      "title": "Golden Signals",
      "order": 10,
      "kind": "trends",
      "collapsible": true,
      "layoutMode": "three-up"
    },
    {
      "id": "health",
      "title": "Health",
      "order": 20,
      "kind": "breakdowns",
      "collapsible": true,
      "layoutMode": "two-up"
    }
  ],
  "panels": [
    {
      "id": "service-stat-cards",
      "layout": {
        "preset": "detail"
      },
      "order": 1,
      "query": {
        "endpoint": "/v1/services/stats",
        "method": "GET",
        "params": {
          "service": "{serviceName}"
        }
      },
      "title": "Service Stats",
      "panelType": "stat-cards-grid",
      "sectionId": "key-metrics"
    },
    {
      "id": "service-request-rate",
      "layout": {
        "preset": "trend"
      },
      "order": 10,
      "query": {
        "endpoint": "/v1/services/timeseries",
        "method": "GET",
        "params": {
          "service": "{serviceName}",
          "interval": "5m"
        }
      },
      "title": "Request Rate",
      "titleIcon": "TrendingUp",
      "panelType": "request",
      "sectionId": "golden-signals"
    },
    {
      "id": "service-error-rate",
      "layout": {
        "preset": "trend"
      },
      "order": 20,
      "query": {
        "endpoint": "/v1/services/timeseries",
        "method": "GET",
        "params": {
          "service": "{serviceName}",
          "interval": "5m"
        }
      },
      "title": "Error Rate",
      "titleIcon": "AlertCircle",
      "panelType": "error-rate",
      "sectionId": "golden-signals"
    },
    {
      "id": "service-p95-latency",
      "layout": {
        "preset": "trend"
      },
      "order": 30,
      "query": {
        "endpoint": "/v1/services/timeseries",
        "method": "GET",
        "params": {
          "service": "{serviceName}",
          "interval": "5m"
        }
      },
      "title": "p95 Latency",
      "titleIcon": "Clock",
      "valueKey": "p95",
      "panelType": "latency",
      "sectionId": "golden-signals"
    },
    {
      "id": "service-scorecard",
      "layout": {
        "preset": "breakdown"
      },
      "order": 40,
      "query": {
        "endpoint": "/v1/spans/red/service-scorecard",
        "method": "GET",
        "params": {
          "service": "{serviceName}"
        }
      },
      "title": "Service Scorecard",
      "titleIcon": "Activity",
      "panelType": "scorecard",
      "sectionId": "health"
    },
    {
      "id": "service-apdex",
      "layout": {
        "preset": "breakdown"
      },
      "order": 50,
      "query": {
        "endpoint": "/v1/spans/red/apdex",
        "method": "GET",
        "params": {
          "service": "{serviceName}",
          "satisfied_ms": 300,
          "tolerating_ms": 1200
        }
      },
      "title": "Apdex Score",
      "titleIcon": "Target",
      "valueKey": "apdex",
      "panelType": "gauge",
      "sectionId": "health"
    }
  ]
}
