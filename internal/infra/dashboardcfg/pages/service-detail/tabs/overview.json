{
  "id": "overview",
  "pageId": "service-detail",
  "label": "Overview",
  "order": 10,
  "sections": [
    {
      "id": "key-metrics",
      "title": "Key Metrics",
      "order": 5,
      "kind": "details",
      "collapsible": true,
      "layoutMode": "stack"
    },
    {
      "id": "golden-signals",
      "title": "Golden Signals",
      "order": 10,
      "kind": "trends",
      "collapsible": true,
      "layoutMode": "three-up"
    },
    {
      "id": "health",
      "title": "Health",
      "order": 20,
      "kind": "breakdowns",
      "collapsible": true,
      "layoutMode": "two-up"
    }
  ],
  "panels": [
    {
      "id": "service-stat-cards",
      "layout": {
        "preset": "detail"
      },
      "order": 1,
      "query": {
        "endpoint": "/v1/services/stats",
        "method": "GET",
        "params": {
          "service": "{serviceName}"
        }
      },
      "title": "Service Stats",
      "description": "Shows aggregate KPIs for this service including throughput, error percentage, and latency percentiles. Use these numbers as a quick health check before diving into trends.",
      "panelType": "stat-cards-grid",
      "sectionId": "key-metrics"
    },
    {
      "id": "service-request-rate",
      "layout": {
        "preset": "trend"
      },
      "order": 10,
      "query": {
        "endpoint": "/v1/services/timeseries",
        "method": "GET",
        "params": {
          "service": "{serviceName}",
          "interval": "5m"
        }
      },
      "title": "Request Rate",
      "description": "Tracks the number of requests per second handled by this service over time. Watch for unexpected drops that may indicate upstream issues or sudden spikes signaling traffic surges.",
      "titleIcon": "TrendingUp",
      "panelType": "request",
      "sectionId": "golden-signals"
    },
    {
      "id": "service-error-rate",
      "layout": {
        "preset": "trend"
      },
      "order": 20,
      "query": {
        "endpoint": "/v1/services/timeseries",
        "method": "GET",
        "params": {
          "service": "{serviceName}",
          "interval": "5m"
        }
      },
      "title": "Error Rate",
      "description": "Shows the percentage of failed requests for this service over time. Look for sustained increases or sharp spikes that correlate with deployments or dependency failures.",
      "titleIcon": "AlertCircle",
      "panelType": "error-rate",
      "sectionId": "golden-signals"
    },
    {
      "id": "service-p95-latency",
      "layout": {
        "preset": "trend"
      },
      "order": 30,
      "query": {
        "endpoint": "/v1/services/timeseries",
        "method": "GET",
        "params": {
          "service": "{serviceName}",
          "interval": "5m"
        }
      },
      "title": "p95 Latency",
      "description": "Tracks the 95th-percentile response time for this service over time. Rising p95 values often indicate resource contention, slow dependencies, or degraded downstream performance.",
      "titleIcon": "Clock",
      "valueKey": "p95",
      "panelType": "latency",
      "sectionId": "golden-signals"
    },
    {
      "id": "service-apdex",
      "layout": {
        "preset": "breakdown"
      },
      "order": 50,
      "query": {
        "endpoint": "/v1/spans/red/apdex",
        "method": "GET",
        "params": {
          "service": "{serviceName}",
          "satisfied_ms": 300,
          "tolerating_ms": 1200
        }
      },
      "title": "Apdex Score",
      "description": "Represents user satisfaction for this service on a 0-to-1 scale based on response-time thresholds. Scores below 0.85 suggest a meaningful portion of requests are too slow for users.",
      "titleIcon": "Target",
      "valueKey": "apdex",
      "panelType": "gauge",
      "sectionId": "health"
    }
  ]
}
