  "panels": [
    {
      "id": "node-cpu-time",
      "layout": {
        "preset": "trend"
      },
      "order": 10,
      "query": {
        "endpoint": "/v1/infrastructure/cpu/time",
        "method": "GET",
        "params": {
          "host": "{host}"
        }
      },
      "title": "CPU Time",
      "description": "Tracks cumulative CPU time consumed on this node, broken down by mode (user, system, iowait). High iowait values suggest disk or network bottlenecks.",
      "titleIcon": "Cpu",
      "panelType": "request",
      "sectionId": "cpu"
    },
    {
      "id": "node-load-average",
      "layout": {
        "preset": "trend"
      },
      "order": 20,
      "query": {
        "endpoint": "/v1/infrastructure/cpu/load-average",
        "method": "GET",
        "params": {
          "host": "{host}"
        }
      },
      "title": "Load Average",
      "description": "Shows the system load average for this node over time. Values exceeding the CPU core count indicate processes are queuing for execution.",
      "titleIcon": "Activity",
      "panelType": "request",
      "sectionId": "cpu"
    },
    {
      "id": "node-mem-usage",
      "layout": {
        "preset": "trend"
      },
      "order": 30,
      "query": {
        "endpoint": "/v1/infrastructure/memory/usage",
        "method": "GET",
        "params": {
          "host": "{host}"
        }
      },
      "title": "Memory Usage",
      "description": "Tracks absolute memory consumption on this node over time. Compare used versus available memory to assess remaining headroom.",
      "titleIcon": "HardDrive",
      "panelType": "request",
      "sectionId": "memory"
    },
    {
      "id": "node-swap",
      "layout": {
        "preset": "trend"
      },
      "order": 40,
      "query": {
        "endpoint": "/v1/infrastructure/memory/swap",
        "method": "GET",
        "params": {
          "host": "{host}"
        }
      },
      "title": "Swap Usage",
      "description": "Tracks swap space utilization on this node over time. Active swapping degrades performance significantly and often signals insufficient physical memory.",
      "titleIcon": "Repeat",
      "panelType": "request",
      "sectionId": "memory"
    },
    {
      "id": "node-disk-io",
      "layout": {
        "preset": "trend"
      },
      "order": 50,
      "query": {
        "endpoint": "/v1/infrastructure/disk/io",
        "method": "GET",
        "params": {
          "host": "{host}"
        }
      },
      "title": "Disk I/O",
      "description": "Tracks disk read and write throughput on this node over time. Sudden increases may correlate with log rotation, backups, or compaction jobs.",
      "titleIcon": "HardDrive",
      "panelType": "request",
      "sectionId": "disk"
    },
    {
      "id": "node-disk-ops",
      "layout": {
        "preset": "trend"
      },
      "order": 60,
      "query": {
        "endpoint": "/v1/infrastructure/disk/operations",
        "method": "GET",
        "params": {
          "host": "{host}"
        }
      },
      "title": "Disk Operations",
      "description": "Tracks the rate of disk read and write operations (IOPS) on this node. High IOPS with increased latency can indicate disk saturation.",
      "titleIcon": "HardDrive",
      "panelType": "request",
      "sectionId": "disk"
    },
    {
      "id": "node-network-io",
      "layout": {
        "preset": "trend"
      },
      "order": 70,
      "query": {
        "endpoint": "/v1/infrastructure/network/io",
        "method": "GET",
        "params": {
          "host": "{host}"
        }
      },
      "title": "Network I/O",
      "description": "Tracks inbound and outbound network throughput on this node over time. Watch for asymmetric traffic patterns that may indicate misconfigured load balancing.",
      "titleIcon": "Wifi",
      "panelType": "request",
      "sectionId": "network"
    },
    {
      "id": "node-network-errors",
      "layout": {
        "preset": "trend"
      },
      "order": 80,
      "query": {
        "endpoint": "/v1/infrastructure/network/errors",
        "method": "GET",
        "params": {
          "host": "{host}"
        }
      },
      "title": "Network Errors",
      "description": "Tracks network-level errors (drops, retransmits) on this node over time. Any sustained error rate warrants investigation into NIC or switch health.",
      "titleIcon": "AlertCircle",
      "panelType": "request",
      "sectionId": "network"
    }
  ]
}
