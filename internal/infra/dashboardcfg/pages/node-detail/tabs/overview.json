  "panels": [
    {
      "id": "node-cpu",
      "layout": {
        "preset": "kpi"
      },
      "order": 10,
      "query": {
        "endpoint": "/v1/infrastructure/resource-utilisation/avg-cpu",
        "method": "GET",
        "params": {
          "host": "{host}"
        }
      },
      "title": "Avg CPU",
      "description": "Shows the average CPU utilization percentage for this node. Sustained values above 80% may indicate the need to scale or redistribute workloads.",
      "titleIcon": "Cpu",
      "panelType": "stat-card",
      "sectionId": "summary"
    },
    {
      "id": "node-memory",
      "layout": {
        "preset": "kpi"
      },
      "order": 20,
      "query": {
        "endpoint": "/v1/infrastructure/resource-utilisation/avg-memory",
        "method": "GET",
        "params": {
          "host": "{host}"
        }
      },
      "title": "Avg Memory",
      "description": "Shows the average memory utilization percentage for this node. High values with low headroom increase the risk of OOM kills.",
      "titleIcon": "HardDrive",
      "panelType": "stat-card",
      "sectionId": "summary"
    },
    {
      "id": "node-network",
      "layout": {
        "preset": "kpi"
      },
      "order": 30,
      "query": {
        "endpoint": "/v1/infrastructure/resource-utilisation/avg-network",
        "method": "GET",
        "params": {
          "host": "{host}"
        }
      },
      "title": "Avg Network",
      "description": "Shows the average network throughput for this node. Watch for values approaching interface bandwidth limits.",
      "titleIcon": "Wifi",
      "panelType": "stat-card",
      "sectionId": "summary"
    },
    {
      "id": "node-conn-pool",
      "layout": {
        "preset": "kpi"
      },
      "order": 40,
      "query": {
        "endpoint": "/v1/infrastructure/resource-utilisation/avg-conn-pool",
        "method": "GET",
        "params": {
          "host": "{host}"
        }
      },
      "title": "Avg Conn Pool",
      "description": "Shows the average connection pool utilization for services on this node. High pool usage can lead to connection queuing and increased latency.",
      "titleIcon": "Link",
      "panelType": "stat-card",
      "sectionId": "summary"
    },
    {
      "id": "node-cpu-usage",
      "layout": {
        "preset": "trend"
      },
      "order": 50,
      "query": {
        "endpoint": "/v1/infrastructure/cpu/usage-percentage",
