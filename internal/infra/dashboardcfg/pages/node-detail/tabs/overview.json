      "panelType": "request",
      "sectionId": "usage"
    },
    {
      "id": "node-memory-usage",
      "layout": {
        "preset": "trend"
      },
      "order": 60,
      "query": {
        "endpoint": "/v1/infrastructure/memory/usage-percentage",
