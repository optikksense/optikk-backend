{
  "id": "latency-analysis",
  "pageId": "metrics",
  "label": "Latency Analysis",
  "order": 40,
  "sections": [
    {
      "id": "summary",
      "title": "Latency Overview",
      "order": 10,
      "kind": "summary",
      "collapsible": true,
      "layoutMode": "kpi-strip"
    },
    {
      "id": "trends",
      "title": "Latency Trends",
      "order": 20,
      "kind": "trends",
      "collapsible": true,
      "layoutMode": "two-up"
    },
    {
      "id": "distribution",
      "title": "Distribution Analysis",
      "order": 30,
      "kind": "breakdowns",
      "collapsible": true,
      "layoutMode": "two-up"
    },
    {
      "id": "offenders",
      "title": "Top Offenders",
      "order": 40,
      "kind": "details",
      "collapsible": true,
      "layoutMode": "two-up"
    }
  ],
  "panels": [
    {
      "formatter": "ms",
      "id": "stat-p50",
      "layout": {
        "preset": "kpi"
      },
      "order": 10,
      "query": {
        "endpoint": "/v1/spans/red/summary",
        "method": "GET"
      },
      "title": "P50 Latency",
      "description": "Median request latency across all services. This is the latency most users experience under normal conditions.",
      "titleIcon": "Clock",
      "valueField": "avg_p50_ms",
      "panelType": "stat-card",
      "sectionId": "summary"
    },
    {
      "formatter": "ms",
      "id": "stat-p95",
      "layout": {
        "preset": "kpi"
      },
      "order": 20,
      "query": {
        "endpoint": "/v1/spans/red/summary",
        "method": "GET"
      },
      "title": "P95 Latency",
      "description": "95th-percentile latency. Rising values indicate that the slowest 5% of requests are getting worse, often the first sign of saturation.",
      "titleIcon": "Clock",
      "valueField": "avg_p95_ms",
      "panelType": "stat-card",
      "sectionId": "summary"
    },
    {
      "formatter": "ms",
      "id": "stat-p99",
      "layout": {
        "preset": "kpi"
      },
      "order": 30,
      "query": {
        "endpoint": "/v1/spans/red/summary",
        "method": "GET"
      },
      "title": "P99 Latency",
      "description": "99th-percentile latency. This captures worst-case tail latency; sustained increases may indicate resource contention or GC pauses.",
      "titleIcon": "AlertCircle",
      "valueField": "avg_p99_ms",
      "panelType": "stat-card",
      "sectionId": "summary"
    },
    {
      "formatter": "number",
      "id": "stat-total-spans",
      "layout": {
        "preset": "kpi"
      },
      "order": 40,
      "query": {
        "endpoint": "/v1/spans/red/summary",
        "method": "GET"
      },
      "title": "Total Spans",
      "description": "Total number of spans analyzed in the selected time window. Provides context for the statistical significance of the percentile values.",
      "titleIcon": "Layers",
      "valueField": "total_span_count",
      "panelType": "stat-card",
      "sectionId": "summary"
    },
    {
      "groupByKey": "service_name",
      "id": "p95-latency-timeseries",
      "layout": {
        "preset": "trend"
      },
      "order": 10,
      "query": {
        "endpoint": "/v1/spans/red/p95-latency",
        "method": "GET"
      },
      "title": "P95 Latency by Service",
      "description": "Plots 95th-percentile latency over time grouped by service. Diverging lines help isolate which service is the source of a latency regression.",
      "titleIcon": "TrendingUp",
      "valueKey": "p95_ms",
      "panelType": "latency",
      "sectionId": "trends"
    },
    {
      "groupByKey": "bucket_label",
      "id": "histogram",
      "layout": {
        "preset": "breakdown"
      },
      "order": 20,
      "query": {
        "endpoint": "/v1/latency/histogram",
        "method": "GET"
      },
      "title": "Latency Distribution",
      "description": "Shows the distribution of request durations across latency buckets. A long right tail indicates outlier requests that may disproportionately affect user experience.",
      "titleIcon": "BarChart3",
      "labelKey": "bucket_label",
      "valueKey": "span_count",
      "panelType": "bar",
      "sectionId": "trends"
    },
    {
      "id": "heatmap",
      "layout": {
        "preset": "breakdown"
      },
      "order": 10,
      "query": {
        "endpoint": "/v1/latency/heatmap",
        "method": "GET",
        "params": {
          "interval": "5m"
        }
      },
      "title": "Latency Heatmap",
      "description": "Visualizes request latency over time with color intensity representing request density at each duration band. Hot bands shifting upward over time indicate progressive latency degradation.",
      "titleIcon": "Activity",
      "xKey": "time_bucket",
      "yKey": "latency_bucket",
      "valueKey": "span_count",
      "panelType": "heatmap",
      "sectionId": "distribution"
    },
    {
      "groupByKey": "service_name",
      "id": "latency-breakdown",
      "layout": {
        "preset": "breakdown"
      },
      "order": 20,
      "query": {
        "endpoint": "/v1/spans/latency-breakdown",
        "method": "GET"
      },
      "title": "Latency Budget by Service",
      "description": "Shows total time spent in each service. Services consuming disproportionate latency budget are prime candidates for optimization.",
      "titleIcon": "PieChart",
      "labelKey": "serviceName",
      "valueKey": "totalMs",
      "panelType": "bar",
      "sectionId": "distribution"
    },
    {
      "id": "top-slow-operations",
      "layout": {
        "preset": "detail"
      },
      "order": 10,
      "query": {
        "endpoint": "/v1/spans/red/top-slow-operations",
        "method": "GET",
        "params": {
          "limit": 20
        }
      },
      "title": "Top Slowest Operations (p99)",
      "description": "Lists operations ranked by 99th-percentile duration, showing the worst tail-latency offenders. Focus optimization efforts on the top entries for maximum user-impact improvement.",
      "titleIcon": "TrendingDown",
      "panelType": "table",
      "sectionId": "offenders"
    },
    {
      "id": "top-error-operations-latency",
      "layout": {
        "preset": "detail"
      },
      "order": 20,
      "query": {
        "endpoint": "/v1/spans/red/top-error-operations",
        "method": "GET",
        "params": {
          "limit": 20
        }
      },
      "title": "Top Error Operations",
      "description": "Lists operations ranked by error rate. High error rates often correlate with latency spikes due to retries and fallback logic.",
      "titleIcon": "AlertTriangle",
      "panelType": "table",
      "sectionId": "offenders"
    }
  ]
}
