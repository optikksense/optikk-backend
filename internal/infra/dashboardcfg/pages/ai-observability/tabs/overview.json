{
  "id": "overview",
  "pageId": "ai-observability",
  "label": "Overview",
  "order": 10,
  "sections": [
    {
      "id": "summary",
      "title": "Key Metrics",
      "order": 10,
      "kind": "summary",
      "collapsible": true,
      "layoutMode": "kpi-strip"
    },
    {
      "id": "trends",
      "title": "Golden Signals",
      "order": 20,
      "kind": "trends",
      "collapsible": true,
      "layoutMode": "two-up"
    }
  ],
  "panels": [
    {
      "formatter": "number",
      "id": "summary-total-requests",
      "layout": {
        "preset": "kpi"
      },
      "order": 10,
      "query": {
        "endpoint": "/v1/ai/summary",
        "method": "GET"
      },
      "title": "Total Requests",
      "titleIcon": "Activity",
      "valueField": "request_count",
      "panelType": "stat-card",
      "sectionId": "summary"
    },
    {
      "formatter": "number",
      "id": "summary-total-cost",
      "layout": {
        "preset": "kpi"
      },
      "order": 20,
      "query": {
        "endpoint": "/v1/ai/summary",
        "method": "GET"
      },
      "title": "Total Cost",
      "titleIcon": "DollarSign",
      "valueField": "total_cost_usd",
      "panelType": "stat-card",
      "sectionId": "summary"
    },
    {
      "formatter": "number",
      "id": "summary-guardrail-blocks",
      "layout": {
        "preset": "kpi"
      },
      "order": 30,
      "query": {
        "endpoint": "/v1/ai/summary",
        "method": "GET"
      },
      "title": "Guardrail Blocks",
      "titleIcon": "Shield",
      "valueField": "guardrail_count",
      "panelType": "stat-card",
      "sectionId": "summary"
    },
    {
      "formatter": "number",
      "id": "summary-pii-detections",
      "layout": {
        "preset": "kpi"
      },
      "order": 40,
      "query": {
        "endpoint": "/v1/ai/summary",
        "method": "GET"
      },
      "title": "PII Detections",
      "titleIcon": "Eye",
      "valueField": "pii_count",
      "panelType": "stat-card",
      "sectionId": "summary"
    },
    {
      "groupByKey": "model_name",
      "id": "qps",
      "layout": {
        "preset": "trend"
      },
      "order": 50,
      "query": {
        "endpoint": "/v1/ai/performance/timeseries",
        "method": "GET",
        "params": {
          "interval": "5m"
        }
      },
      "title": "QPS per Model",
      "titleIcon": "TrendingUp",
      "valueKey": "qps",
      "panelType": "ai-line",
      "sectionId": "trends"
    },
    {
      "groupByKey": "model_name",
      "id": "avg-latency",
      "layout": {
        "preset": "trend"
      },
      "order": 60,
      "query": {
        "endpoint": "/v1/ai/performance/timeseries",
        "method": "GET",
        "params": {
          "interval": "5m"
        }
      },
      "title": "Avg Latency ms per Model",
      "titleIcon": "Clock",
      "valueKey": "avg_latency_ms",
      "panelType": "ai-line",
      "sectionId": "trends"
    },
    {
      "groupByKey": "model_name",
      "id": "cost-over-time",
      "layout": {
        "preset": "trend"
      },
      "order": 70,
      "query": {
        "endpoint": "/v1/ai/cost/timeseries",
        "method": "GET",
        "params": {
          "interval": "5m"
        }
      },
      "title": "Cost per Interval (USD)",
      "titleIcon": "DollarSign",
      "valueKey": "cost_per_interval",
      "yDecimals": 4,
      "yPrefix": "$",
      "panelType": "ai-line",
      "sectionId": "trends"
    },
    {
      "groupByKey": "model_name",
      "id": "pii-detections",
      "layout": {
        "preset": "trend"
      },
      "order": 80,
      "query": {
        "endpoint": "/v1/ai/security/timeseries",
        "method": "GET",
        "params": {
          "interval": "5m"
        }
      },
      "title": "PII Detections per Model",
      "titleIcon": "ShieldCheck",
      "valueKey": "pii_count",
      "panelType": "ai-line",
      "sectionId": "trends"
    }
  ]
}
