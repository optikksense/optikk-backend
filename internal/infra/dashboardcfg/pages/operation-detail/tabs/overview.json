{
  "id": "overview",
  "pageId": "operation-detail",
  "label": "Overview",
  "order": 10,
  "sections": [
    {
      "id": "signals",
      "title": "Signals",
      "order": 10,
      "kind": "trends",
      "collapsible": true,
      "layoutMode": "three-up"
    },
    {
      "id": "quality",
      "title": "Quality",
      "order": 20,
      "kind": "breakdowns",
      "collapsible": true,
      "layoutMode": "two-up"
    }
  ],
  "panels": [
    {
      "id": "op-request-rate",
      "layout": {
        "preset": "trend"
      },
      "order": 10,
      "query": {
        "endpoint": "/v1/spans/red/request-rate",
        "method": "GET",
        "params": {
          "service": "{serviceName}",
          "operation": "{operationName}"
        }
      },
      "title": "Request Rate",
      "description": "Tracks requests per second for this operation over time. Watch for unexpected dips that may indicate callers failing before reaching this endpoint, or spikes from retry storms.",
      "titleIcon": "TrendingUp",
      "panelType": "request",
      "sectionId": "signals"
    },
    {
      "id": "op-error-rate",
      "layout": {
        "preset": "trend"
      },
      "order": 20,
      "query": {
        "endpoint": "/v1/spans/red/error-rate",
        "method": "GET",
        "params": {
          "service": "{serviceName}",
          "operation": "{operationName}"
        }
      },
      "title": "Error Rate",
      "description": "Shows the percentage of invocations of this operation that result in an error over time. Correlate spikes with deployment events or dependency outages to find the root cause.",
      "titleIcon": "AlertCircle",
      "panelType": "error-rate",
      "sectionId": "signals"
    },
    {
      "id": "op-p95-latency",
      "layout": {
        "preset": "trend"
      },
      "order": 30,
      "query": {
        "endpoint": "/v1/spans/red/p95-latency",
        "method": "GET",
        "params": {
          "service": "{serviceName}",
          "operation": "{operationName}"
        }
      },
      "title": "p95 Latency",
      "description": "Tracks the 95th-percentile duration for this operation over time. Gradual climbs may point to growing payload sizes or connection-pool exhaustion.",
      "titleIcon": "Clock",
      "valueKey": "p95",
      "panelType": "latency",
      "sectionId": "signals"
    },
    {
      "id": "op-apdex",
      "layout": {
        "preset": "breakdown"
      },
      "order": 40,
      "query": {
        "endpoint": "/v1/spans/red/apdex",
        "method": "GET",
        "params": {
          "service": "{serviceName}",
          "operation": "{operationName}",
          "satisfied_ms": 300,
          "tolerating_ms": 1200
        }
      },
      "title": "Apdex Score",
      "description": "Measures end-user satisfaction for this operation on a 0-to-1 scale using configurable latency thresholds. Scores below 0.85 indicate a significant share of requests exceed acceptable response times.",
      "titleIcon": "Target",
      "valueKey": "apdex",
      "panelType": "gauge",
      "sectionId": "quality"
    }
  ]
}
