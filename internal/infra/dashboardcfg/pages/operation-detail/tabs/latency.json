{
  "id": "latency",
  "pageId": "operation-detail",
  "label": "Latency",
  "order": 20,
  "sections": [
    {
      "id": "breakdowns",
      "title": "Latency",
      "order": 30,
      "collapsible": true,
      "sectionTemplate": "two-up"
    }
  ],
  "panels": [
    {
      "id": "op-latency-histogram",
      "order": 10,
      "query": {
        "endpoint": "/v1/latency/histogram",
        "method": "GET",
        "params": {
          "service": "{serviceName}",
          "operation": "{operationName}"
        }
      },
      "title": "Latency Histogram",
      "description": "Shows the distribution of response times for this operation across latency buckets. Look for bimodal shapes or long tails that reveal slow outlier requests.",
      "titleIcon": "BarChart2",
      "panelType": "latency-histogram",
      "sectionId": "breakdowns",
      "layoutVariant": "standard-chart"
    },
    {
      "id": "op-latency-heatmap",
      "order": 20,
      "query": {
        "endpoint": "/v1/latency/heatmap",
        "method": "GET",
        "params": {
          "service": "{serviceName}",
          "operation": "{operationName}",
          "interval": "5m"
        }
      },
      "title": "Latency Heatmap",
      "description": "Visualizes response-time density for this operation over time, with darker bands indicating more requests at that latency. Watch for new hot bands appearing at higher latencies, which signal performance degradation.",
      "titleIcon": "Grid",
      "panelType": "latency-heatmap",
      "sectionId": "breakdowns",
      "layoutVariant": "standard-chart"
    }
  ]
}
