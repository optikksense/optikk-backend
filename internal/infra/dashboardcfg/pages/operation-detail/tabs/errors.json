{
  "id": "errors",
  "pageId": "operation-detail",
  "label": "Errors",
  "order": 30,
  "sections": [
    {
      "id": "trends",
      "title": "Golden Signals",
      "order": 20,
      "kind": "trends",
      "collapsible": true,
      "layoutMode": "stack"
    },
    {
      "id": "breakdowns",
      "title": "Breakdowns",
      "order": 30,
      "kind": "breakdowns",
      "collapsible": true,
      "layoutMode": "stack"
    }
  ],
  "panels": [
    {
      "groupByKey": "exceptionType",
      "id": "op-exception-rate",
      "layout": {
        "preset": "trend"
      },
      "order": 10,
      "query": {
        "endpoint": "/v1/spans/exception-rate-by-type",
        "method": "GET",
        "params": {
          "service": "{serviceName}",
          "operation": "{operationName}"
        }
      },
      "title": "Exception Rate by Type",
      "description": "Tracks the count of exceptions thrown by this operation over time, broken down by exception type. A new or rapidly growing line indicates a regression introduced by a recent change.",
      "titleIcon": "Bug",
      "valueKey": "count",
      "panelType": "exception-type-line",
      "sectionId": "trends"
    },
    {
      "groupByKey": "http_route",
      "id": "op-5xx-by-route",
      "layout": {
        "preset": "breakdown"
      },
      "order": 20,
      "query": {
        "endpoint": "/v1/spans/http-5xx-by-route",
        "method": "GET",
        "params": {
          "service": "{serviceName}",
          "operation": "{operationName}"
        }
      },
      "title": "HTTP 5xx by Route",
      "description": "Shows server-error counts for this operation split by HTTP route. Use the comparison to determine whether 5xx errors are isolated to a single route or spread across multiple paths.",
      "titleIcon": "AlertTriangle",
      "valueKey": "count",
      "panelType": "bar",
      "sectionId": "breakdowns"
    }
  ]
}
