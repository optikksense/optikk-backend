{
  "id": "connections",
  "pageId": "database-detail",
  "label": "Connections",
  "order": 50,
  "sections": [
    {
      "id": "trends",
      "title": "Connections",
      "order": 20,
      "collapsible": true,
      "sectionTemplate": "two-up"
    }
  ],
  "panels": [
    {
      "id": "db-connection-count",
      "order": 10,
      "query": {
        "endpoint": "/v1/database/connections/count",
        "method": "GET",
        "params": {
          "db_system": "{dbSystem}"
        }
      },
      "title": "Connection Count",
      "description": "Tracks the number of active connections to this database over time. Watch for sustained growth that may approach the connection limit.",
      "titleIcon": "Link",
      "panelType": "request",
      "sectionId": "trends",
      "layoutVariant": "standard-chart"
    },
    {
      "id": "db-connection-pending",
      "order": 20,
      "query": {
        "endpoint": "/v1/database/connections/pending",
        "method": "GET",
        "params": {
          "db_system": "{dbSystem}"
        }
      },
      "title": "Pending Connections",
      "description": "Shows connections waiting to be established to this database. A rising count indicates pool exhaustion or slow handshake times.",
      "titleIcon": "Clock",
      "panelType": "request",
      "sectionId": "trends",
      "layoutVariant": "standard-chart"
    },
    {
      "id": "db-connection-timeouts",
      "order": 30,
      "query": {
        "endpoint": "/v1/database/connections/timeout-rate",
        "method": "GET",
        "params": {
          "db_system": "{dbSystem}"
        }
      },
      "title": "Connection Timeouts",
      "description": "Tracks the rate of connection timeouts for this database. Any non-zero value warrants investigation into pool sizing or network issues.",
      "titleIcon": "AlertCircle",
      "panelType": "request",
      "sectionId": "trends",
      "layoutVariant": "standard-chart"
    }
  ]
}
