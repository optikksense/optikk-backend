{
  "id": "overview",
  "pageId": "redis-detail",
  "label": "Overview",
  "order": 10,
  "sections": [
    {
      "id": "summary",
      "title": "Traffic Overview",
      "order": 10,
      "collapsible": true,
      "sectionTemplate": "two-up"
    },
    {
      "id": "cache",
      "title": "Cache",
      "order": 20,
      "collapsible": true,
      "sectionTemplate": "chart-grid-plus-details"
    }
  ],
  "panels": [
    {
      "id": "redis-clients",
      "order": 10,
      "query": {
        "endpoint": "/v1/saturation/redis/clients",
        "method": "GET",
        "params": {
          "instance": "{instance}"
        }
      },
      "title": "Connected Clients",
      "description": "Tracks the number of client connections to this Redis instance over time. Sudden increases may indicate connection leaks in application code.",
      "titleIcon": "Users",
      "panelType": "request",
      "sectionId": "summary",
      "layoutVariant": "standard-chart"
    },
    {
      "id": "redis-commands",
      "order": 20,
      "query": {
        "endpoint": "/v1/saturation/redis/commands",
        "method": "GET",
        "params": {
          "instance": "{instance}"
        }
      },
      "title": "Commands/sec",
      "description": "Tracks the command throughput for this Redis instance over time. Correlate with latency to determine if slowdowns are load-driven.",
      "titleIcon": "Zap",
      "panelType": "request",
      "sectionId": "summary",
      "layoutVariant": "standard-chart"
    },
    {
      "id": "redis-hit-rate",
      "order": 30,
      "query": {
        "endpoint": "/v1/saturation/redis/cache-hit-rate",
        "method": "GET",
        "params": {
          "instance": "{instance}"
        }
      },
      "title": "Cache Hit Rate",
      "description": "Shows the ratio of cache hits to total lookups for this Redis instance. Compare hits versus misses to evaluate caching effectiveness.",
      "titleIcon": "Target",
      "valueKey": "hit_rate",
      "panelType": "gauge",
      "sectionId": "cache",
      "layoutVariant": "summary"
    },
    {
      "id": "redis-keyspace",
      "order": 40,
      "query": {
        "endpoint": "/v1/saturation/redis/keyspace",
        "method": "GET",
        "params": {
          "instance": "{instance}"
        }
      },
      "title": "Keyspace",
      "description": "Tracks the total number of keys stored in this Redis instance over time. Rapid growth without corresponding expiries may lead to memory pressure.",
      "titleIcon": "Key",
      "panelType": "request",
      "sectionId": "cache",
      "layoutVariant": "standard-chart"
    },
    {
      "id": "redis-key-expiries",
      "order": 50,
      "query": {
        "endpoint": "/v1/saturation/redis/key-expiries",
        "method": "GET",
        "params": {
          "instance": "{instance}"
        }
      },
      "title": "Key Expiries",
      "description": "Tracks the rate of key expirations for this Redis instance over time. A steady expiry rate is healthy; a sudden drop may mean TTLs are no longer being set.",
      "titleIcon": "Clock",
      "panelType": "request",
      "sectionId": "cache",
      "layoutVariant": "standard-chart"
    }
  ]
}
