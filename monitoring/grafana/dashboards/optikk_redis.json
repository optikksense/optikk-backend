{
  "annotations": {"list": []},
  "description": "Redis command traffic as seen by the app's go-redis hook — commands/sec by command, latency p50/p95/p99, error ratio.",
  "editable": false,
  "graphTooltip": 1,
  "liveNow": false,
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["optikk", "redis"],
  "templating": {
    "list": [
      {
        "name": "cmd",
        "label": "Command",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "definition": "label_values(optikk_redis_commands_total, cmd)",
        "query": "label_values(optikk_redis_commands_total, cmd)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "current": {"selected": true, "text": ["All"], "value": ["$__all"]}
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "title": "Optikk Redis",
  "uid": "optikk-redis",
  "version": 1,
  "panels": [
    {
      "title": "Commands/sec by command",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum by (cmd) (rate(optikk_redis_commands_total{cmd=~\"$cmd\",result=\"ok\"}[1m]))",
          "legendFormat": "{{cmd}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "title": "Errors/sec by command",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum by (cmd) (rate(optikk_redis_commands_total{cmd=~\"$cmd\",result=\"err\"}[1m]))",
          "legendFormat": "{{cmd}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "title": "p50 latency",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (cmd, le) (rate(optikk_redis_command_duration_seconds_bucket{cmd=~\"$cmd\"}[5m])))",
          "legendFormat": "{{cmd}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "title": "p95 latency",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (cmd, le) (rate(optikk_redis_command_duration_seconds_bucket{cmd=~\"$cmd\"}[5m])))",
          "legendFormat": "{{cmd}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "title": "p99 latency",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (cmd, le) (rate(optikk_redis_command_duration_seconds_bucket{cmd=~\"$cmd\"}[5m])))",
          "legendFormat": "{{cmd}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "title": "Error ratio",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 5, "w": 8, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "100 * sum(rate(optikk_redis_commands_total{result=\"err\"}[5m])) / clamp_min(sum(rate(optikk_redis_commands_total[5m])), 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 5}]}}}
    },
    {
      "title": "Total commands/sec",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 5, "w": 8, "x": 8, "y": 16},
      "targets": [
        {"expr": "sum(rate(optikk_redis_commands_total[1m]))", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "title": "Top 10 slowest commands (p95)",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 5, "w": 8, "x": 16, "y": 16},
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum by (cmd, le) (rate(optikk_redis_command_duration_seconds_bucket[5m]))))",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    }
  ]
}
