{
  "annotations": {"list": []},
  "description": "Service-wide health overview — HTTP + gRPC traffic, error ratios, DB/Redis/Kafka subsystem summary, Go runtime basics. Start here; drill into subsystem dashboards for root cause.",
  "editable": false,
  "graphTooltip": 1,
  "liveNow": false,
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["optikk", "overview"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "title": "Optikk Overview",
  "uid": "optikk-overview",
  "version": 1,
  "panels": [
    {
      "title": "HTTP req/s",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "targets": [
        {"expr": "sum(rate(optikk_http_requests_total[1m]))", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "title": "HTTP 5xx %",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "targets": [
        {
          "expr": "100 * sum(rate(optikk_http_requests_total{status_class=\"5xx\"}[5m])) / clamp_min(sum(rate(optikk_http_requests_total[5m])), 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 5}]}}}
    },
    {
      "title": "gRPC calls/s",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "targets": [
        {"expr": "sum(rate(optikk_grpc_started_total[1m]))", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "title": "gRPC non-OK %",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "100 * sum(rate(optikk_grpc_handled_total{code!=\"OK\"}[5m])) / clamp_min(sum(rate(optikk_grpc_handled_total[5m])), 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 5}]}}}
    },
    {
      "title": "Ingest records/s",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "targets": [
        {"expr": "sum(rate(optikk_ingest_records_total{result=\"ok\"}[1m]))", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "title": "Kafka consumer lag",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "targets": [
        {"expr": "sum(optikk_kafka_consumer_lag_records)", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 10000}, {"color": "red", "value": 100000}]}}}
    },
    {
      "title": "HTTP req/s by status class",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "sum by (status_class) (rate(optikk_http_requests_total[1m]))",
          "legendFormat": "{{status_class}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "title": "HTTP p95 by route (top 5)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "topk(5, histogram_quantile(0.95, sum by (route, le) (rate(optikk_http_request_duration_seconds_bucket[5m]))))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "title": "gRPC p99 by method",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (method, le) (rate(optikk_grpc_handling_duration_seconds_bucket[5m])))",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "title": "Ingest records/s by signal",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {
          "expr": "sum by (signal, result) (rate(optikk_ingest_records_total[1m]))",
          "legendFormat": "{{signal}} {{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "title": "DB query rate by system",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 20},
      "targets": [
        {
          "expr": "sum by (system) (rate(optikk_db_queries_total[1m]))",
          "legendFormat": "{{system}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "title": "Redis commands/s",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 20},
      "targets": [
        {
          "expr": "sum by (result) (rate(optikk_redis_commands_total[1m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "title": "Auth denials (5m rate)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 20},
      "targets": [
        {
          "expr": "sum by (reason) (rate(optikk_auth_denied_total[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "title": "Go goroutines",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
      "targets": [
        {"expr": "go_goroutines", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "title": "Go heap in use",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
      "targets": [
        {"expr": "go_memstats_heap_inuse_bytes", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    }
  ]
}
